# ایپلیکیشن کی ترتیب
# Application Configuration

# ڈیٹابیس کا URL
DATABASE_URL=postgresql://user:password@localhost:5432/medical_ai

# اگر SQLite استعمال کریں (ترقیاتی ماحول کے لیے):
# DATABASE_URL=sqlite:///./medical_ai.db

# FastAPI ہوسٹ اور پورٹ
HOST=0.0.0.0
PORT=8000

# سیکیورٹی
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256

# ML ماڈل کا راستہ
MODEL_PATH=backend/app/ml/pneumonia_model.onnx

# ڈیبگ ماڈ
DEBUG=True

# CORS Origins (production میں یہ محدود کریں)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Frontend URL
FRONTEND_URL=http://localhost:3000
